# ─── UMS Frontend Environment Variables ──────────────────────────────────
# Copy this file to .env for local development.

# ─── HQNhat External API (https://api.hqnhat.id.vn) ───────────────────────
# Base URL for the HQNhat UMS API
VITE_HQNHAT_API_BASE_URL=https://api.hqnhat.id.vn

# Bearer JWT token for HQNhat API authentication.
# In production, rotate this token or replace with OAuth flow.
VITE_HQNHAT_API_TOKEN=YOUR_HQNHAT_JWT_TOKEN_HERE

# ─── Internal Backend (UMS) ───────────────────────────────────────────────
# Leave UNSET to use relative /api (recommended for production).
# Set absolute URL only when backend is on a different domain.
# VITE_API_BASE_URL=

# Override the dev proxy target (only used when running `npm run dev`)
# VITE_API_TARGET=http://localhost:5000

# ─── App Info ───────────────────────────────────────────────────────────
VITE_APP_NAME=UMS - Hệ thống Quản lý Đại học
VITE_APP_VERSION=1.0.0

# ─── Environment ────────────────────────────────────────────────────────
VITE_NODE_ENV=development