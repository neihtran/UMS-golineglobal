# .env.example
# UMS Frontend Environment Variables
# Copy this file to .env.local (for local dev) or set via hosting dashboard (for production)

# ─── API ────────────────────────────────────────────────────────────────
# How the frontend talks to the backend. Three options:
#
# 1. Relative path (RECOMMENDED for production) — Leave UNSET.
#    Frontend uses '/api' which works with same-domain reverse proxy
#    (nginx, Vercel rewrites, Railway static, Cloudflare, etc.)
#    Best practice: avoid CORS issues entirely by sharing one domain.
#
# 2. Absolute URL — Set when backend is on a different domain.
#    Example: VITE_API_BASE_URL=https://api.golineglobal.com/api
#    Requires ALLOWED_ORIGINS in backend env to include frontend domain.
#
# 3. Local development — Frontend (5173) + Backend (5000) on same machine.
#    Vite dev server proxies /api → http://localhost:5000 automatically,
#    so you don't need to set VITE_API_BASE_URL at all.

# VITE_API_BASE_URL=

# Override the dev proxy target (only used when running `npm run dev`)
# Defaults to http://localhost:5000
# VITE_API_TARGET=http://localhost:5000

# ─── App Info ───────────────────────────────────────────────────────
VITE_APP_NAME=UMS - Hệ thống Quản lý Đại học
VITE_APP_VERSION=1.0.0

# ─── Environment ────────────────────────────────────────────────────
VITE_NODE_ENV=production
