# Test environment — uses separate database (ums_test_db)
# Load via: jest --config jest.config.js (dotenv tự động load .env.test qua setup.ts)

NODE_ENV=test
PORT=5099
FRONTEND_URL=http://localhost:5173

# MongoDB — test database riêng (KHÔNG dùng ums_db)
MONGODB_URI=mongodb://ums_admin:ums_secure_password@localhost:27017/ums_test_db?authSource=admin

JWT_ACCESS_SECRET=test-access-secret-at-least-32-characters-long-for-security
JWT_REFRESH_SECRET=test-refresh-secret-at-least-32-characters-long-for-security
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

TOTP_ISSUER=UMS-University
TOTP_SECRET=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

ALLOWED_ORIGINS=http://localhost:5173

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

MFA_REQUIRED_ROLES=SUPER_ADMIN,ADMIN

# Hqnhat — disable sync trong test
HQNHAT_API_URL=https://api.hqnhat.id.vn
HQNHAT_API_TOKEN=
HQNHAT_API_USERNAME=
HQNHAT_API_PASSWORD=
HQNHAT_API_TIMEOUT_MS=5000
HQNHAT_API_RETRY_MAX=1
HQNHAT_SYNC_ENABLED=false