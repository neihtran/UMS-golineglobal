# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/ums_db
# Hoặc MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ums_db

# JWT — THAY ĐỔI TRƯỚC KHI DEPLOY
JWT_ACCESS_SECRET=ums-access-secret-change-in-production-min-32chars
JWT_REFRESH_SECRET=ums-refresh-secret-change-in-production-min-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MFA (TOTP) — THAY ĐỔI TRƯỚC KHI DEPLOY
TOTP_ISSUER=UMS-University
TOTP_SECRET=base32-encoded-secret-for-otplib

# National Systems (INT-01) — điền khi cần
HEMIS_API_URL=https://hemis.example.com/api
HEMIS_API_KEY=
VNEID_API_URL=https://vneid.example.com/api
VNEID_API_KEY=
VGCA_API_URL=https://vgca.example.com/api
VGCA_API_KEY=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
