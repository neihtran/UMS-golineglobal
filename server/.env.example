# server/.env.example
# UMS Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:80

# ─── MongoDB ────────────────────────────────────────────────────────────
# Local development
# MONGODB_URI=mongodb://localhost:27017/ums_db

# Docker / Production (with Docker Compose)
MONGODB_URI=mongodb://ums_admin:ums_secure_password@mongodb:27017/ums_db?authSource=admin

# MongoDB Atlas (Cloud Production)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ums_db?retryWrites=true&w=majority

# ─── JWT Secrets (IMPORTANT: Change these in production!) ─────────────────
# Generate secure secrets: openssl rand -base64 64
# Minimum 32 characters each
JWT_ACCESS_SECRET=your-super-secure-access-secret-at-least-32-chars-long-here
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-at-least-32-chars-long-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── TOTP MFA ───────────────────────────────────────────────────────────
# Secret key for TOTP authenticator apps (Base32 encoded)
# Generate with: node -e "console.log(require('speakeasy').generateSecret({name:'UMS-University'}).base32)"
TOTP_SECRET=
TOTP_ISSUER=UMS-University

# ─── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:80,http://localhost:5173

# ─── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── File Upload ────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── MFA Required Roles ─────────────────────────────────────────────────
# Roles that must have MFA enabled
MFA_REQUIRED_ROLES=SUPER_ADMIN,ADMIN,HIEU_TRUONG,PHO_HIEU_TRUONG

# ─── External API: api.hqnhat.id.vn ──────────────────────────────────────
# Bật/tắt tích hợp với hệ thống api.hqnhat.id.vn (SIS legacy)
HQNHAT_API_URL=https://api.hqnhat.id.vn
# Ưu tiên dùng static token (recommended)
HQNHAT_API_TOKEN=
# Hoặc dùng username/password (alternative flow)
HQNHAT_API_USERNAME=
HQNHAT_API_PASSWORD=
HQNHAT_API_TIMEOUT_MS=30000
HQNHAT_API_RETRY_MAX=3

# Scheduler — bật các cron job đồng bộ
HQNHAT_SYNC_ENABLED=false
HQNHAT_SYNC_FACULTIES_CRON=0 2 * * *
HQNHAT_SYNC_MAJORS_CRON=0 3 * * *
HQNHAT_SYNC_COURSEGROUPS_CRON=0 3 * * *
HQNHAT_SYNC_COURSES_CRON=0 4 * * *
HQNHAT_SYNC_CURRICULUMS_CRON=0 5 * * *
HQNHAT_SYNC_CLASSES_CRON=*/30 * * * *
HQNHAT_SYNC_STUDENTS_CRON=*/30 * * * *
