{
  "name": "ums-server",
  "version": "1.0.0",
  "description": "UMS Backend — University Management System API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "mock": "node --import tsx src/mock/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "seed": "tsx src/seed/seedAll.ts",
    "seed:hrm": "tsx src/seed/seedHrm.ts",
    "seed:sis": "tsx src/seed/seedSis.ts",
    "seed:dms": "tsx src/seed/seedDms.ts",
    "seed:exam": "tsx src/seed/seedExam.ts",
    "seed:lms": "tsx src/seed/seedLms.ts",
    "seed:portal": "tsx src/seed/seedPortal.ts",
    "seed:fin": "tsx src/seed/seedFin.ts",
    "seed:ktx": "tsx src/seed/seedKtx.ts",
    "seed:rit": "tsx src/seed/seedRit.ts",
    "seed:int": "tsx src/seed/seedInt.ts",
    "seed:bi": "tsx src/seed/seedBi.ts",
    "seed:qa": "tsx src/seed/seedQa.ts",
    "seed:dce": "tsx src/seed/seedDce.ts",
    "seed:lib": "tsx src/seed/seedLib.ts",
    "seed:wms": "tsx src/seed/seedWms.ts",
    "seed:pms": "tsx src/seed/seedPms.ts",
    "seed:ocr": "tsx src/seed/seedOcr.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
